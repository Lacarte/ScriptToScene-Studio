[
  { "title":"...", "scene":1, "start":0.06, "end":1.48, "prompt":"...", "type_of_scene":"video" },
  { "title":"...", "scene":2, "start":1.48, "end":2.38, "prompt":"...", "type_of_scene":"text" }
]

